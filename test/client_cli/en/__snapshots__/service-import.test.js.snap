// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`CLI help interface for 'service import' should be expected english 1`] = `
"Usage: frodo service import [options] [host] [realm] [username] [password]

Import AM services.

Arguments:
  host                           AM base URL, e.g.:
                                 https://cdk.iam.example.com/am. To use a
                                 connection profile, just specify a unique
                                 substring or alias.
  realm                          Realm. Specify realm as '/' for the root realm
                                 or 'realm' or '/parent/child' otherwise.
                                 (default: "alpha" for Identity Cloud tenants,
                                 "/" otherwise.)
  username                       Username to login with. Must be an admin user
                                 with appropriate rights to manage
                                 authentication journeys/trees.
  password                       Password.

Options:
  -a, --all                      Import all services from a single file.
  -A, --all-separate             Import all services from separate files
                                 <id>.service.json.
  -C, --clean                    Remove existing service(s) before importing.
  -f, --file <file>              Name of the file to import SAML Entity(s) from.
                                 Ignored with -A.
  -g, --global                   Import service(s) as global service(s).
                                 (default: false)
  -i, --service-id <service-id>  Service id. If specified, -a and -A are
                                 ignored.
  -r, --current-realm            Import service(s) into the current realm. Use
                                 this flag if you exported a service from one
                                 realm and are importing into another realm.
                                 (default: false)
  -h, --help                     Help
  -hh, --help-more               Help with all options.
  -hhh, --help-all               Help with all options, environment variables,
                                 and usage examples.
"
`;
