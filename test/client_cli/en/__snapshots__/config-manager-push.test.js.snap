exports[`CLI help interface for 'config-manager push' should be expected english 1`] = `
"Usage: frodo config-manager push [options] [command]

Import configuration optimized for CI/CD pipelines (format compatible with
fr-config-manager).

Options:
  -h, --help            Help

Commands:
  email-provider        Import email provider configuration.
  email-templates       Import email template objects.
  endpoints             Import custom endpoints objects.
  help                  display help for command
  internal-roles        Import internal roles.
  kba                   Import kba configuration.
  locales               Import custom locales objects.
  password-policy       Import password-policy objects.
  terms-and-conditions  Import terms and conditions.
  themes                Import themes.
"
`;
