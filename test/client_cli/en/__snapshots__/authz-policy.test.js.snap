exports[`CLI help interface for 'authz policy' should be expected english 1`] = `
"Usage: frodo authz policy [options] [command]

Manages authorization policies.

Options:
  -h, --help        Help
  -hh, --help-more  Help with all options.
  -hhh, --help-all  Help with all options, environment variables, and usage
