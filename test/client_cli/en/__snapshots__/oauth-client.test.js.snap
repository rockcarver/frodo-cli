exports[`CLI help interface for 'oauth client' should be expected english 1`] = `
"Usage: frodo oauth client [options] [command]

Manage OAuth2 clients.

Options:
  -h, --help        Help
  -hh, --help-more  Help with all options.
  -hhh, --help-all  Help with all options, environment variables, and usage
