exports[`CLI help interface for 'esv secret version' should be expected english 1`] = `
"Usage: frodo esv secret version [options] [command]

Manage secret versions.

Deployment: Cloud-only

Options:
  -h, --help        Help
  -hh, --help-more  Help with all options.
  -hhh, --help-all  Help with all options, environment variables, and usage
                    examples.

Commands:
  help              display help for command

  (Cloud-only):
  activate          Activate versions of secrets.
  create            Create new version of secret.
  deactivate        Deactivate versions of secrets.
  delete            Delete versions of secrets.
  list              List versions of secret.
"
