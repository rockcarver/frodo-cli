        "response": {
          "bodySize": 937,
          "content": {
            "mimeType": "application/json;charset=UTF-8",
            "size": 937,
            "text": "{\"result\":[{\"_id\":\"user-1\",\"_rev\":\"-64423344\",\"serviceName\":\"user\",\"displayName\":\"DoesUserExist\",\"description\":\"Checks whether the username in node state already exists in IDM.\",\"outcomes\":[\"true\",\"false\"],\"outputs\":[\"*\",\"userExists\"],\"inputs\":[\"*\",\"username\"],\"script\":\"var username = nodeState.get(\\\"username\\\");\\n\\nif (!username) {\\n  logger.error(\\\"DoesUserExist: no username in node state\\\");\\n  action.goTo(\\\"false\\\");\\n} else {\\n  var result = openidm.query(\\\"managed/user\\\", {\\n    _queryFilter: 'userName eq \\\"' + String(username).replace(/\\\"/g, '\\\\\\\\\\\"') + '\\\"',\\n    _fields: \\\"_id\\\"\\n  });\\n\\n  var exists = result && result.resultCount > 0;\\n  nodeState.putShared(\\\"userExists\\\", exists);\\n  action.goTo(exists ? \\\"true\\\" : \\\"false\\\");\\n}\",\"errorOutcome\":true,\"tags\":[\"utilities\"],\"properties\":{}}],\"resultCount\":1,\"pagedResultsCookie\":null,\"totalPagedResultsPolicy\":\"EXACT\",\"totalPagedResults\":1,\"remainingPagedResults\":-1}"
          },
