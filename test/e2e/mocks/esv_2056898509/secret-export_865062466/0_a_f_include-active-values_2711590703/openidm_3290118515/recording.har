            "params": [],
            "text": "{\"type\":\"text/javascript\",\"globals\":{\"secretIds\":[\"esv-test-secret\",\"esv-test-secret-2\",\"esv-test-secret-3\"],\"decrypt\":false,\"target\":null},\"source\":\"var secrets = {}\\nfor (var i = 0; i < secretIds.length; i++) {\\n  var secretValue = identityServer.getProperty(secretIds[i].split(\\\"-\\\").join(\\\".\\\"));\\n  if (secretValue) {\\n    if (decrypt || target) {\\n      secrets[secretIds[i]] = secretValue;\\n    } else {\\n      secrets[secretIds[i]] = openidm.encrypt(secretValue, null, \\\"idm.password.encryption\\\");\\n    }\\n  }\\n}\\nJSON.stringify(secrets);\"}"
          },
          "queryString": [
