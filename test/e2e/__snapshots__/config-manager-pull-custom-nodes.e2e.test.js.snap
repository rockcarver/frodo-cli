exports[`frodo config-manager pull custom-nodes "frodo config-manager pull custom-nodes -D configManagerPullCustomNodesDir0 -m forgeops": should export all custom-nodes in fr-config manager style. 1`] = `0`;

exports[`frodo config-manager pull custom-nodes "frodo config-manager pull custom-nodes -D configManagerPullCustomNodesDir0 -m forgeops": should export all custom-nodes in fr-config manager style. 2`] = `""`;

exports[`frodo config-manager pull custom-nodes "frodo config-manager pull custom-nodes -D configManagerPullCustomNodesDir0 -m forgeops": should export all custom-nodes in fr-config manager style.: configManagerPullCustomNodesDir0/custom-nodes/nodes/DoesUserExist/DoesUserExist.js 1`] = `
"var username = nodeState.get("username");

if (!username) {
  logger.error("DoesUserExist: no username in node state");
  action.goTo("false");
} else {
  var result = openidm.query("managed/user", {
    _queryFilter: 'userName eq "' + String(username).replace(/"/g, '\\\\"') + '"',
    _fields: "_id"
  });

  var exists = result && result.resultCount > 0;
  nodeState.putShared("userExists", exists);
  action.goTo(exists ? "true" : "false");
}
"
`;

