                    "isDefault": false,
                    "location": "https://login.microsoftonline.com/login.srf",
                  },
                  {
                    "binding": "urn:oasis:names:tc:SAML:2.0:bindings:PAOS",
                    "index": 2,
                    "isDefault": false,
                    "location": "https://login.microsoftonline.com/login.srf",
                  },
                ],
                "singleLogoutService": [
                  {
                    "binding": "urn:oasis:names:tc:SAML:2.0:bindings:HTTP-POST",
                    "location": "https://login.microsoftonline.com/login.srf",
                  },
                ],
