            },
            {
              "displayName": "none",
              "id": "none",
            },
          ],
          "_type": {
            "_id": "ScriptedDecisionNode",
            "collection": true,
            "name": "Scripted Decision",
            "version": "1.0",
          },
          "inputs": [
            "*",
            "mode",
            "level",
          ],
          "outcomes": [
            "shared and level",
            "shared only",
            "level only",
            "none",
          ],
          "outputs": [
            "*",
