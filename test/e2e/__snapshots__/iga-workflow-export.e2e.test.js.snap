                "try {",
                "    var decision = {",
                "        "decision": "approved"",
                "    }",
                "    if(skipApproval){",
                "        decision.comment = "Request auto-approved due to request context: " + context;",
                "    }",
                "    openidm.action('iga/governance/requests/' + requestId, 'POST', decision, queryParams);",
                "",
