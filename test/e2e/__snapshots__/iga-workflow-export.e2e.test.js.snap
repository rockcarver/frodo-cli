        },
        "status": "published",
        "steps": [
          {
            "approvalMode": "any",
            "approvalTask": {
              "actors": {
                "isExpression": true,
                "value": [
                  "(function() {",
                  "    var systemSettings = openidm.action('iga/commons/config/iga_access_request', 'GET', {}, {});",
                  "    return systemSettings.defaultApprover;",
                  "})()",
                ],
              },
              "approvalMode": "any",
              "events": {
                "assignment": {
                  "notification": "requestAssigned",
                },
                "expiration": {
                  "action": "reject",
                  "actors": [],
                  "date": {
                    "isExpression": true,
                    "value": [
                      "(new Date(new Date().getTime()+(7*24*60*60*1000))).toISOString()",
                    ],
                  },
