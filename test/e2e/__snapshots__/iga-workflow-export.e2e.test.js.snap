                          ""managed/user/" + requestIndex.applicationOwner[0].id",
                        ],
                      },
                    },
                  ],
                  "date": {
                    "isExpression": true,
                    "value": [
                      "(new Date(new Date().getTime()+(5*1*24*60*60*1000))).toISOString()",
                    ],
