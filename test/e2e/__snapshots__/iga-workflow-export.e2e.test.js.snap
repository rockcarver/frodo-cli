                "        failureReason = 'Governance role modification failed: Error modifying role ' + request.role.roleId + ', status: ' + request.role.status + '. Error message: ' + e.message;",
                "      }",
                "",
                "      decision = {",
                "          'status': 'complete',",
                "          'decision': 'approved',",
