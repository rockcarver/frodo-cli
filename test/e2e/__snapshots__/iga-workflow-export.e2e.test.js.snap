                },
                "reminder": {
                  "date": {
                    "isExpression": true,
                    "value": [
                      "(new Date(new Date().getTime()+(3*24*60*60*1000))).toISOString()",
                    ],
                  },
                  "frequency": 3,
                  "notification": "requestReminder",
                },
              },
              "nextStep": [
                {
                  "condition": null,
                  "outcome": "FULFILL",
                  "step": "scriptTask-87ad089a5484",
                },
                {
                  "condition": null,
                  "outcome": "DENY",
                  "step": "scriptTask-aec6c36b3a45",
