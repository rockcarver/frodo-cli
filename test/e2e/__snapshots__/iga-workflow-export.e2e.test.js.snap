          },
          {
            "displayName": "Create Removal Request",
            "name": "scriptTask-91769554db51",
            "scriptTask": {
              "language": "javascript",
              "nextStep": [
                {
                  "condition": [
                    "true",
                  ],
                  "outcome": "done",
