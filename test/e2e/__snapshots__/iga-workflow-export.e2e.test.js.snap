                    "value": [
                      ""managed/user/" + ((requestIndex.entitlementOwner && requestIndex.entitlementOwner.length > 0) ? requestIndex.entitlementOwner[0].id : requestIndex.applicationOwner[0].id)",
                    ],
                  },
                  "permissions": {
                    "approve": true,
