                  },
                  "type": "user",
                },
              ],
              "events": {
                "escalationDate": 5,
                "escalationTimeSpan": "day(s)",
                "escalationType": "applicationOwner",
                "expirationDate": 7,
                "expirationDateType": "duration",
                "expirationDateVariable": "",
