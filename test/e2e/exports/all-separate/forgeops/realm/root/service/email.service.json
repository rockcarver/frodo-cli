{
  "service": {
    "email": {
      "_id": "",
      "_type": {
        "_id": "email",
        "collection": false,
        "name": "Email Service"
      },
      "emailAddressAttribute": "mail",
      "emailImplClassName": "org.forgerock.openam.services.email.MailServerImpl",
      "emailRateLimitSeconds": 1,
      "from": "from@test.com",
      "location": "/",
      "message": "content",
      "nextDescendents": [
        {
          "_id": "SMTP",
          "_type": {
            "_id": "smtpTransports",
            "collection": true,
            "name": "SMTP"
          },
          "emailImplClassName": "org.forgerock.openam.services.email.MailServerImpl",
          "hostname": "smtp.example.com",
          "port": 465,
          "sslState": "SSL",
          "username": "username"
        },
        {
          "_id": "Microsoft",
          "_type": {
            "_id": "microsoftRestTransports",
            "collection": true,
            "name": "Microsoft Graph API"
          },
          "clientId": "clientId",
          "emailEndpoint": "https://graph.microsoft.com/v1.0/users/<user_id>/sendMail",
          "emailImplClassName": "org.forgerock.openam.services.email.rest.MicrosoftRestMailServer",
          "scope": "https://graph.microsoft.com/.default",
          "tokenEndpoint": "https://login.microsoftonline.com/<tennant_id>/oauth2/v2.0/token"
        }
      ],
      "port": 465,
      "sslState": "SSL",
      "subject": "subject",
      "transportType": "[Empty]"
    }
  }
}
